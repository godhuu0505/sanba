# ===== Google / Gemini =====
# Gemini API key (AI Studio). For Vertex AI, set GOOGLE_GENAI_USE_VERTEXAI=true instead.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=kikitori-dev
GOOGLE_CLOUD_LOCATION=us-central1
# Path to service account json mounted into containers (optional in local dev)
GOOGLE_APPLICATION_CREDENTIALS=

# Model selection
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_REASONING_MODEL=gemini-2.5-flash

# ===== LiveKit =====
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ===== API service =====
API_HOST=0.0.0.0
API_PORT=8080

# ===== Access control (issue #8) =====
# Override with a strong secret in prod (Secret Manager). Signs session invites.
SESSION_SIGNING_SECRET=dev-only-insecure-secret-change-me
INVITE_TTL_SECONDS=3600
LIVEKIT_TOKEN_TTL_MINUTES=60
# Local-dev only: allow "dev:<session_id>:<role>" invites without signing.
AUTH_DEV_BYPASS=false
JOIN_RATE_PER_MINUTE=30
# Context ingestion (issue #6): API writes chunks to the same ES index as the agent.
MAX_CONTEXT_CHARS=200000

# ===== Data governance (issue #10) =====
MASK_PII_BEFORE_INDEX=true
REQUIRE_CONSENT=true
DATA_RETENTION_DAYS=30

# ===== Firestore (use emulator locally) =====
FIRESTORE_EMULATOR_HOST=firestore:8200

# ===== Elasticsearch (RAG grounding + past-session search) =====
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_API_KEY=
GEMINI_EMBED_MODEL=text-embedding-004

# ===== Observability =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=kikitori-agent
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ===== Web =====
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
NEXT_PUBLIC_API_URL=http://localhost:8080
