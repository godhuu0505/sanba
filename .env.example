# ============================================================================
# SANBA — ローカル開発の環境変数テンプレート
#
#   `just setup` が .env.example → .env.local を自動生成する (手動なら cp .env.example .env.local)。
#   既定値だけで `just up` が通るローカル設定。`.env.local` は gitignore 済 (コミット禁止)。
#
# 構成:
#   [1] 必須 — これだけで `just up` (アプリ最小構成) が動く
#   [2] 本物の音声/AI を通すために必要 (無くても起動はする → fallback)
#   [3] 任意 — `just up-full` で重ねる補助スタック (可観測性 / LLMOps / DORA)
#
# どのサービスが読むか:
#   agent = apps/agent / api = apps/api / web = apps/web(ビルド時) / tools = 補助スタック
# ============================================================================

# ===== [1] 必須: LiveKit (リアルタイム音声) ===== agent, api
# docker-compose の livekit (--dev) は devkey/secret を発行する。一致させること。
# LIVEKIT_URL は「ブラウザへ返す join URL」= host から見た localhost。api のサーバ側 publish
# (analysis.progress/visual) と agent の worker 接続は、コンテナからサービス名で届く必要があるため
# compose 側が別途 LIVEKIT_SERVER_URL(api) / LIVEKIT_URL(agent) を ws://livekit:7880 に振り向ける
# (それぞれ API_LIVEKIT_URL / AGENT_LIVEKIT_URL で上書き可)。ネイティブ実行時は全て localhost で足りる。
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ===== [1] 必須: API サービス ===== api
# 待受アドレス/ポートは env では制御しない (config.py は読まない)。コンテナの起動コマンドが
# 0.0.0.0:${PORT:-8080} に固定でバインドし、Cloud Run が $PORT を注入する (Dockerfile 参照)。
# ネイティブ実行は `just api-dev` (uvicorn --port 8080)。← ここに API_HOST/API_PORT を書いても
# 無視されるだけで「バインド先を絞れた」と誤認するため、あえて置かない。
# web からの CORS 許可オリジン (カンマ区切り)。これは実際に config.py が読む。
ALLOWED_ORIGINS=http://localhost:3000

# ===== [1] 必須: アクセス制御 (issue #8) ===== api
# 本番では必ず強いシークレットに差し替える (Secret Manager)。招待トークンの署名に使う。
SESSION_SIGNING_SECRET=dev-only-insecure-secret-change-me
INVITE_TTL_SECONDS=3600
LIVEKIT_TOKEN_TTL_MINUTES=60
# ローカル限定: "dev:<session_id>:<role>" 形式の招待を署名なしで許可する。本番では false。
# また Google ログイン検証も素通しし、固定の dev identity を返す (ADR-0012)。
AUTH_DEV_BYPASS=true
JOIN_RATE_PER_MINUTE=30
MAX_CONTEXT_CHARS=200000

# ===== [1] 必須: Google ログイン (本人確認 / ADR-0012) ===== api, web
# OAuth 2.0 Web クライアント ID (Google Cloud Console で発行)。秘匿物ではない。
#   - api: GOOGLE_OAUTH_CLIENT_ID … ID トークン検証の aud に使う (サーバ側検証)。
#   - web: NEXT_PUBLIC_GOOGLE_CLIENT_ID … ビルド時に焼き込み GIS ログインボタンに使う。
# 両方空のままなら AUTH_DEV_BYPASS=true の dev モードで動く (ローカル開発)。
# OAuth client *secret* は本方式 (ID トークン検証のみ) では不要なので設定しない。
GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_OAUTH_CLIENT_ID}

# ログイン nonce チャレンジ (ADR-0047) ===== api
# ID トークン注入対策。true にすると create/join で ID トークンの nonce claim をサーバ照合する。
# 段階リリース用フラグ（既定 false）: 実環境で web の nonce フローを確認してから true にする。
# AUTH_DEV_BYPASS=true のローカルでは値に関わらず nonce 検証はスキップされる。
REQUIRE_LOGIN_NONCE=false

# ===== [2] 任意: Google ドライブ取り込み (ADR-0044) ===== web
# Google Picker 表示用のブラウザ API キー (Google Cloud Console で発行。HTTP リファラ制限を推奨)。
# 同プロジェクトで Google Drive API / Google Picker API の有効化が必要。未設定なら
# 「Google ドライブから選ぶ」導線は利用不可の案内になる (ローカルアップロードは影響なし)。
# Drive のアクセス権は drive.file スコープ (Picker で選んだファイルのみ) をログイン時に求める。
NEXT_PUBLIC_GOOGLE_API_KEY=

# ===== [1] 必須: 管理者 (管理画面 / ADR-0014) ===== api
# 管理画面 (/admin) を使える Google アカウントの email 許可リスト (カンマ区切り)。
# 検証済み identity の email をサーバ側で照合する。AUTH_DEV_BYPASS=true でも照合するため、
# dev の固定 identity (dev@sanba.local) を入れておくと `just up` で /admin が開ける。
ADMIN_EMAILS=dev@sanba.local

# ルーム(セッション)作成の許可リスト (ADR-0012 §3) ===== api
# セッションを作成できる Google アカウント。email("a@b.com") かドメイン("example.com") の
# カンマ区切り。空 = 制限なし（現行の「ログイン済みなら誰でも作成可」を維持）。admin は常に可。
ROOM_CREATOR_ALLOWLIST=

# ===== [1] 必須: データガバナンス (issue #10) ===== agent, api
MASK_PII_BEFORE_INDEX=true
REQUIRE_CONSENT=true
DATA_RETENTION_DAYS=30

# ===== [1] 必須: Firestore (ローカルはエミュレータ) ===== agent, api
# docker 内のサービス名:ポート。未設定なら in-memory にフォールバックする。
# api もセッション/要件のリーダー兼ライターになった (ADR-0014 §15) ため両方が読む。
FIRESTORE_EMULATOR_HOST=firestore:8200

# ===== [1] 必須: Elasticsearch (RAG 根拠付け + 過去セッション検索) ===== agent, api
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-001

# ===== [1] 必須: Web (ビルド時に焼き込まれる NEXT_PUBLIC_*) ===== web
# docker compose は build.args 経由でイメージへ渡す。ブラウザから見たエンドポイント。
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ============================================================================
# [2] 本物の音声 / AI 経路に必要 (未設定でも起動はするが fallback に落ちる)
# ============================================================================

# ===== Google / Gemini ===== agent, api
# 二経路:
#   (A) AI Studio: GOOGLE_API_KEY を入れる。要前払いクレジット (2026/03 以降、$300 無料は Gemini API 非対象)。
#   (B) Vertex AI: GOOGLE_GENAI_USE_VERTEXAI=true / GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION を設定。
#                  GCP 無料 $300 クレジット対象。ローカルでは下記 SANBA_ADC_FILE に ADC のパスを指す。
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=sanba-dev
GOOGLE_CLOUD_LOCATION=us-central1
# Vertex AI 経路でローカル起動するときだけ設定: docker-compose が read-only でマウントする ADC ファイル。
# 未設定なら /dev/null をマウント（AI Studio 既定経路では ADC 不要）。複数アカウントは CLOUDSDK_CONFIG 配下。
# 例: SANBA_ADC_FILE=${HOME}/.config/gcloud/application_default_credentials.json
SANBA_ADC_FILE=

# 音声 S2S (Gemini Live) は Vertex AI GA の gemini-live-2.5-flash-native-audio に統一する
# （本番は use_vertexai=true / キーレス）。gemini-2.0-flash-live-001 は廃止済みのため使わない。
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio   # 音声 S2S (Gemini Live)
GEMINI_REASONING_MODEL=gemini-2.5-flash       # 文字起こし分析 / ADK 推論
# 音声認識/合成の言語固定 (BCP-47 / ADR-0039)。入力文字起こしのヒントと出力音声の
# language_code に使い、日本語セッションで韓国語/中国語へ誤認識ドリフトするのを抑える。
# 空にするとモデルの自動言語判定に委ねる (従来挙動)。
GEMINI_LANGUAGE=ja-JP

# ===== 音声ターン検出 / セッション安定化 (ADR-0038 / 0039) ===== agent
# エージェントが「参加者が話し終えた」と判定するまでの無音時間 (ms)。大きいほど発話途中に
# 被せて話し始めにくいが、応答開始は遅くなる。0 以下でサーバ既定。
# ADR-0039: 「考えながらの沈黙」で発話が途中確定して分断されるのを抑えるため 800→1200。
TURN_SILENCE_DURATION_MS=1200
# 発話終端検出の感度: low(待ち長め・既定) / high / 空=サーバ既定。
TURN_END_SENSITIVITY=low
# 発話開始検出の感度: low(相槌・環境音で中断されにくい) / high / 空=サーバ既定(既定)。
TURN_START_SENSITIVITY=
# start-of-speech 確定に要する発話長 (ms)。0 以下でサーバ既定。
# ADR-0039: 一瞬の環境音・相槌の漏れで発話が誤って区切られるのを抑えるため 0→100。
TURN_PREFIX_PADDING_MS=100
# 入力ノイズ抑制 (Krisp BVC / ADR-0039)。LiveKit Cloud でのみ実効。雑音・PC 内蔵マイク由来の
# 誤認識を抑える。self-host やプラグイン未導入では自動で無効化 (フェイルソフト)。
NOISE_CANCELLATION_ENABLED=true
# コンテキスト圧縮 (sliding window)。長時間セッションが上限で打ち切られるのを防ぐ (既定 true)。
GEMINI_CONTEXT_WINDOW_COMPRESSION=true
# 回復不能エラーで AgentSession が閉じたときの自動再起動 (1 job あたりの上限 / 初期バックオフ秒)。
VOICE_SESSION_MAX_RESTARTS=3
VOICE_SESSION_RESTART_BACKOFF_S=2.0

# ===== マルチモーダル素材: 画像/動画アップロード (issue #103 / ADR-0004) ===== api
# 画像解析に使う Gemini マルチモーダルモデル。GOOGLE_API_KEY (or Vertex) が無いと観察抽出は空。
GEMINI_VISION_MODEL=gemini-2.5-flash
# 画像/動画 1 件あたりのバイト上限 (メモリ/コスト/帯域のガード)。既定 25MB。
MAX_ASSET_BYTES=25000000
# Cloud Storage バケット名。空ならローカル/テスト用に in-memory へフォールバックする。
GCS_BUCKET=
# 動画解析は未実装 (web では「準備中」でグレーアウト)。true にしても解析はまだ走らない。
ENABLE_VIDEO_ANALYSIS=false

# ===== 外部コネクタ / GitHub 起票 (issue #7 / #39) — 既定で OFF。デモ経路に影響しない ===== agent, api
# agent: README/Issue を grounding として読む。api: 確定要件を Issue として書き出す (POST /export)。
GITHUB_CONNECTOR_ENABLED=false
GITHUB_TOKEN=
GITHUB_REPO=
# セッション単位で選択・保存できるリポジトリの許可リスト（ADR-0027 / api）。
# "owner"（配下すべて）または "owner/name" のカンマ区切り。空 = 制限なし。
# 候補一覧（App 経路含む）・保存・解決後の起票先すべてに掛かる。
GITHUB_REPO_ALLOWLIST=

# ===== GitHub App: ユーザーごとの repo 紐づけ (ADR-0028) — 既定で OFF ===== api
# 連携アカウントが管理する repo を準備画面で選び、深掘りの前提情報として ES に索引する。
# 秘密鍵は Secret Manager 経由で注入する（生のまま置かない）。app_id/slug は秘匿物ではない。
GITHUB_APP_ENABLED=false
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
# GitHub から戻る API コールバック先（App 登録の Setup URL に一致させる）。
GITHUB_APP_CALLBACK_URL=
# 連携保存後にユーザーを戻す web 設定画面の URL（上の API callback とは別物）。
GITHUB_APP_WEB_RETURN_URL=
# user-to-server OAuth（install 時の所有権検証用）。App で "Request user authorization
# (OAuth) during installation" を ON にし、client_id/secret を設定すると検証が有効化する。
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# 索引の総量キャップ（巨大 repo ガード / 関連度優先で超過分はスキップ）。
GITHUB_INDEX_MAX_FILES=1500
GITHUB_INDEX_MAX_TOTAL_BYTES=20000000
GITHUB_INDEX_MAX_FILE_BYTES=200000

# ============================================================================
# [3] 任意: 補助スタック (just up-full で起動)  ===== tools, agent, api
#
# OTLP のエンドポイントは docker-compose.tools.yml が overlay で agent/api に注入する。
# ここでは既定で空にして、アプリ最小構成 (just up) ではテレメトリ送信をスキップさせ、
# 接続エラーの雑音を出さない。本番（Vertex 実行）は endpoint 未指定でも Cloud Trace へ
# 直送する（ADR-0051）。
#
# ネイティブ実行 (just agent-dev 等) からドッカー上の補助スタックへ送りたいときは
# 下のコメントを外して localhost を指す。
# ============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sanba-agent
# OTLP 転送の TLS。localhost collector (平文 gRPC) では true、TLS 終端された外部 OTLP 直送では false。
OTEL_EXPORTER_INSECURE=false

# four-keys が読む対象リポジトリ (DORA 自己計測)。
GITHUB_REPOSITORY=godhuu0505/sanba
