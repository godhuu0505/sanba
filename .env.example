# ---------------------------------------------------------------------------
# Gemini / Vertex AI — the agents' model (required by the hackathon)
# ---------------------------------------------------------------------------
# Option A: Vertex AI (recommended for the hackathon; judges favour Vertex).
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
# Option B: AI Studio key instead of Vertex (set USE_VERTEXAI=false).
# GOOGLE_API_KEY=...

# Reasoning model for the text / multi-agent / eval path.
MODEL=gemini-2.5-flash
# Live (speech-to-speech) model for the voice path. Must be a Live-capable model.
LIVE_MODEL=gemini-2.0-flash-live-001
# Embedding model for Elasticsearch vector search.
EMBEDDING_MODEL=text-embedding-005

# ---------------------------------------------------------------------------
# Elasticsearch — Agentic RAG grounding + past-session recall (sponsor tech)
# Leave unset to run without a backend (tools degrade gracefully; logs -> ./.grill)
# ---------------------------------------------------------------------------
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ES_KNOWLEDGE_INDEX=interview-knowledge
ES_SESSIONS_INDEX=interview-sessions

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVE_WEB_INTERFACE=true
# Set to enable Cloud Trace export (Cloud Run already ships stdout to Logging).
# OTEL_EXPORTER_OTLP_ENDPOINT=
