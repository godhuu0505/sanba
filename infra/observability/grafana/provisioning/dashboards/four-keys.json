{
  "annotations": { "list": [] },
  "editable": true,
  "title": "SANBA — Four Keys (DORA)",
  "uid": "sanba-four-keys",
  "tags": ["devops", "dora", "four-keys"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "デプロイ頻度 (回/日)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "fourkeys_deployment_frequency_per_day", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.033 },
              { "color": "yellow", "value": 0.143 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "変更リードタイム (時間, 中央値)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "fourkeys_lead_time_hours", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "orange", "value": 168 },
              { "color": "red", "value": 730 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "変更失敗率",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "fourkeys_change_failure_rate", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "orange", "value": 0.15 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "平均復旧時間 MTTR (時間, 中央値)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "fourkeys_mttr_hours", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 24 },
              { "color": "red", "value": 168 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "デプロイ頻度の推移 (回/日)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "fourkeys_deployment_frequency_per_day", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "変更失敗率の推移",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [{ "expr": "fourkeys_change_failure_rate", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "データ源 (sample=フォールバック)",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "textMode": "name" },
      "targets": [
        { "expr": "fourkeys_data_source == 1", "legendFormat": "{{source}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "ウィンドウ内デプロイ数 / インシデント数",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "fourkeys_deployments_total", "legendFormat": "deploys", "refId": "A" },
        { "expr": "fourkeys_incidents_total", "legendFormat": "incidents", "refId": "B" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  }
}
