# cp terraform.tfvars.example terraform.tfvars して埋める。
# terraform.tfvars は機微値を含むため gitignore 済 (コミット禁止)。

# ---- 必須 ----
project_id = "sanba-prd"
region     = "us-central1"
image_tag  = "latest" # CI が GITHUB_SHA を渡す。手動 apply 時は固定タグでも可。

# ---- コスト ----
billing_account     = ""    # e.g. "0123AB-456789-CDEF01" → 予算アラートを有効化
monthly_budget_jpy  = 30000
agent_min_instances = 1     # 0 にすると常駐ワーカーが消える代わりにコストを止められる
image_keep_count    = 5     # Artifact Registry に残す直近イメージ数

# ---- ランタイム設定 (平文) ----
use_vertexai = true # 本番は Vertex AI でキーレス。AI Studio キーを使うなら false → SM に google-api-key を投入 (§6.7)
livekit_url  = ""   # 例: "wss://your-project.livekit.cloud" (実音声経路に必須)
elasticsearch_url = "" # マネージド ES のエンドポイント。空なら in-memory にフォールバック
otel_exporter_otlp_endpoint = "" # 例: "http://localhost:4317" (OTel Collector サイドカー)。空ならトレース無効
# Google ログイン (ADR-0012)。OAuth Web クライアント ID。秘匿物ではないので平文。
# web 側は CI の vars.NEXT_PUBLIC_GOOGLE_CLIENT_ID に同じ値を設定する。
google_oauth_client_id = "" # 例: "1234567890-abcdef.apps.googleusercontent.com"

# 管理画面 (/admin) を使える Google アカウントの email 許可リスト (カンマ区切り / ADR-0014)。
# 秘匿物ではないので平文。例: "alice@example.com,bob@example.com"
admin_emails = ""

# ---- 素材バケット / 動画解析パイプライン (ADR-0040) ----
# バケット・Cloud Tasks キュー・worker SA は常に作成される。GCS_BUCKET が api に配線され、
# 画像アップロードも in-memory から GCS 永続化に切り替わる。
# 動画解析の worker Cloud Run service は image が要るため段階導入する:
#   1) 先に worker image を CI で push できるようにする
#   2) enable_video_analysis = true にして apply → worker が立ち、api が enqueue を始める
enable_video_analysis = false
# materials_bucket_name = ""            # 空なら <project_id>-sanba-materials（グローバル一意が必要）
# video_tasks_queue     = "sanba-video-analysis"
# worker_request_timeout_seconds = 900  # 10 分動画の解析が 5 分既定を超えるため延ばす
# max_video_duration_seconds     = 600  # worker が実長 10 分超を failed 化する上限

# ---- 独自ドメイン (Global 外部 HTTPS LB + Google 管理証明書) ----
# OSS なのでドメインはコードに焼かず、各自ここ (または CI の GitHub Variables) で設定する。
# domain が空なら LB を作らず Cloud Run 既定の *.run.app で運用。
# - web_subdomain="" : <domain>/www/api を配信 (apex 配信・従来挙動)。
# - web_subdomain="x": x.<domain> で web を配信、api.x.<domain> で api を配信、
#                      apex/www は x.<domain> へ 301 リダイレクト。
# 例 (メンテナ環境): domain="sanba.net", web_subdomain="youken" → ログインは https://youken.sanba.net。
domain                = ""           # 例: "example.com"（取得後に設定）
web_subdomain         = ""           # 例: "youken"（web をサブドメインに置くとき。空=apex 配信）
manage_dns            = true         # Cloud DNS ゾーンを作り A レコードを LB IP に向ける。別 DNS 運用なら false
# Cloud Domains で登録すると Cloud DNS ゾーンが自動作成され委任済みになる (例: 名前 "sanba-net")。
# その場合は新規作成せず既存ゾーン名を指定して import する (terraform import google_dns_managed_zone.primary[0] …)。
dns_managed_zone_name = "sanba"      # manage_dns=true のときのゾーン名 (既存ゾーンに合わせる)
# DNSSEC 状態。Cloud Domains 由来で DNSSEC 有効なゾーンを import したなら "on"、
# 明示的に無効化するなら "off"。未設定(コメントアウト)なら dnssec_config ブロックを送らず
# GCP 400 エラーでフェイルセーフ動作。移行中ゾーンは "transfer"。
# dns_dnssec_state = "on"   # Cloud Domains 由来のゾーンを import した場合

# ---- シークレット (Secret Manager を値の唯一の置き場にする) ----
# アプリ秘匿値 (livekit/elasticsearch/google) は terraform では扱わない。値は gcloud で
# Secret Manager に直接投入し、投入済みの id を active_app_secret_ids に入れて apply する。
# 詳細は docs/runbooks/deploy-gcp.md「Secret Manager への値投入」。
# session_signing_secret は通常空のまま (terraform が自動生成して SM に格納)。
session_signing_secret = ""
# 作成する箱の集合 (既定で OK)。値は管理しない。
# app_secret_ids        = ["livekit-api-key", "livekit-api-secret", "elasticsearch-api-key"]
# 値を SM に投入したら、その id をここへ足して apply すると Cloud Run に注入される。
# active_app_secret_ids = ["livekit-api-key", "livekit-api-secret"]
