  <diagram id="sanba-devops-cycle" name="5. DevOps サイクル">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="dv0" />
        <mxCell id="dv1" parent="dv0" />
        <mxCell id="dv-title" value="SANBA — DevOps サイクル（つくる・まわす・とどける・みる・しらべる の閉ループ）" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="dv1">
          <mxGeometry x="40" y="10" width="1100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="dv-plan" value="&lt;b&gt;&lt;font style=&quot;font-size:16px&quot;&gt;① つくる（Plan / Code）&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;・Issue（目的ベース）＋ 設計判断の記録&lt;br&gt;・AI エージェント協働（CLAUDE.md / AGENTS.md 規約）&lt;br&gt;・&lt;b&gt;sanba-reviewer&lt;/b&gt;: 過去に対応したバグ・脆弱性を&lt;br&gt;　観点化した専属レビューエージェントでセルフレビュー&lt;br&gt;・Conventional Commits → Pull Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3572B0;fontColor=#ffffff;fontSize=13;align=left;spacing=14;verticalAlign=top;spacingTop=6;" vertex="1" parent="dv1">
          <mxGeometry x="30" y="90" width="470" height="250" as="geometry" />
        </mxCell>
        <mxCell id="dv-ci" value="&lt;b&gt;&lt;font style=&quot;font-size:16px&quot;&gt;② まわす（CI・品質ゲート）&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;・ci.yml: lint / 型 / テスト / build / no-comments&lt;br&gt;・llm-eval.yml: LLM 出力の回帰評価（Gemini judge）&lt;br&gt;・security.yml: pip-audit / npm audit / gitleaks / Trivy、&lt;br&gt;　CodeQL&lt;br&gt;・自動レビュー（Codex・日本語）＋ /security-review&lt;br&gt;・全ゲート＋レビュー通過で main へ merge&lt;br&gt;　（branch protection）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3572B0;fontColor=#ffffff;fontSize=13;align=left;spacing=14;verticalAlign=top;spacingTop=6;" vertex="1" parent="dv1">
          <mxGeometry x="590" y="90" width="470" height="250" as="geometry" />
        </mxCell>
        <mxCell id="dv-cd" value="&lt;b&gt;&lt;font style=&quot;font-size:16px&quot;&gt;③ とどける（CD・鍵レス）&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;・deploy.yml: paths-filter → buildx → Artifact Registry&lt;br&gt;　→ Cloud Run（migrate 先行・失敗時は全 app 停止）&lt;br&gt;・terraform.yml: plan / apply（IaC が単一の正）&lt;br&gt;・Workload Identity Federation（鍵レス）&lt;br&gt;・SLSA provenance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3572B0;fontColor=#ffffff;fontSize=13;align=left;spacing=14;verticalAlign=top;spacingTop=6;" vertex="1" parent="dv1">
          <mxGeometry x="1150" y="90" width="470" height="250" as="geometry" />
        </mxCell>
        <mxCell id="dv-obs" value="&lt;b&gt;&lt;font style=&quot;font-size:16px&quot;&gt;④ みる（本番の可観測性）&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;・OTel trace → &lt;b&gt;Cloud Trace ダッシュボード&lt;/b&gt;（レイテンシ分析）&lt;br&gt;・structlog → Cloud Logging → ログベースメトリクス&lt;br&gt;・&lt;b&gt;Cloud Monitoring ダッシュボード&lt;/b&gt; / アラート&lt;br&gt;　（session_scored = LLM 品質スコア）&lt;br&gt;・&lt;b&gt;Kibana ダッシュボード&lt;/b&gt;（AI コスト・セッション分析）&lt;br&gt;・Four Keys（DORA）自己計測" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3572B0;fontColor=#ffffff;fontSize=13;align=left;spacing=14;verticalAlign=top;spacingTop=6;" vertex="1" parent="dv1">
          <mxGeometry x="1120" y="470" width="500" height="270" as="geometry" />
        </mxCell>
        <mxCell id="dv-inv" value="&lt;b&gt;&lt;font style=&quot;font-size:16px&quot;&gt;⑤ しらべる・なおす（調査・改善）&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;・&lt;b&gt;HolmesGPT&lt;/b&gt;（read-only の外部調査エージェント）が&lt;br&gt;　GCP ログ / Elasticsearch を A2A 経由で横断走査し原因を推定&lt;br&gt;・セッション ID から本番の対話状況を復元してデバッグ&lt;br&gt;・気づきを Issue / 設計判断の記録 / プロンプト改善へ還流" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3572B0;fontColor=#ffffff;fontSize=13;align=left;spacing=14;verticalAlign=top;spacingTop=6;" vertex="1" parent="dv1">
          <mxGeometry x="40" y="470" width="540" height="270" as="geometry" />
        </mxCell>
        <mxCell id="dv-center" value="&lt;b&gt;DevOps&lt;br&gt;closed loop&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFF9B2;strokeColor=#D6B656;fontSize=14;" vertex="1" parent="dv1">
          <mxGeometry x="745" y="372" width="180" height="86" as="geometry" />
        </mxCell>
        <mxCell id="dv-a1" value="git push / PR&lt;br&gt;（CI 起動）" style="html=1;strokeColor=#333333;fontSize=11;verticalAlign=bottom;labelBackgroundColor=none;endArrow=block;strokeWidth=2;" edge="1" parent="dv1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="500" y="215" as="sourcePoint" /><mxPoint x="590" y="215" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="dv-a2" value="merge main&lt;br&gt;（CD 起動）" style="html=1;strokeColor=#333333;fontSize=11;verticalAlign=bottom;labelBackgroundColor=none;endArrow=block;strokeWidth=2;" edge="1" parent="dv1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1060" y="215" as="sourcePoint" /><mxPoint x="1150" y="215" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="dv-a3" value="本番 Cloud Run へデプロイ&lt;br&gt;（テレメトリを常時放流）" style="html=1;strokeColor=#333333;fontSize=12;verticalAlign=middle;align=left;spacingLeft=8;labelBackgroundColor=none;endArrow=block;strokeWidth=2;" edge="1" parent="dv1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1385" y="340" as="sourcePoint" /><mxPoint x="1385" y="470" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="dv-a4" value="ダッシュボード・アラートの&lt;br&gt;異常や気づき" style="html=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;labelBackgroundColor=none;endArrow=block;strokeWidth=2;" edge="1" parent="dv1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1120" y="605" as="sourcePoint" /><mxPoint x="580" y="605" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="dv-a5" value="Issue / 設計判断 / プロンプト改善&lt;br&gt;として次のサイクルへ還流" style="html=1;strokeColor=#333333;fontSize=12;verticalAlign=middle;align=left;spacingLeft=8;labelBackgroundColor=none;endArrow=block;strokeWidth=2;" edge="1" parent="dv1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="290" y="470" as="sourcePoint" /><mxPoint x="290" y="340" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="dv-note" value="原則: 観測できないものは運用できない（新しい処理は必ずトレース / ログ / メトリクスを通す）・指標をハックしない（Four Keys は本質的なボトルネック改善のために計測）。ワークフローの設計判断は docs/reference/ci-cd-workflows.md、リリース手順は docs/how-to/deploy-gcp.md を正とする。" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#D6B656;fontSize=11;align=left;spacing=8;" vertex="1" parent="dv1">
          <mxGeometry x="40" y="790" width="1580" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

